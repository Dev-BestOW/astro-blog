---
import type { Post } from '../utils/posts';
import { formatDate } from '../utils/posts';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<article class="group py-6">
  <a href={`/posts/${post.id}/`} class="block">
    <h2
      class="text-xl font-semibold tracking-tight group-hover:text-blue-600 dark:group-hover:text-blue-400"
    >
      {title}
    </h2>
    <p class="mt-2 line-clamp-2 text-neutral-600 dark:text-neutral-400">
      {description}
    </p>
  </a>
  <div class="mt-3 flex items-center gap-3 text-sm text-neutral-500">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    {
      tags.length > 0 && (
        <div class="flex gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="hover:text-blue-600 dark:hover:text-blue-400"
            >
              #{tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
