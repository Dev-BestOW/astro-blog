---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
// h2, h3만 노출
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 0 && (
    <nav aria-label="목차" class="text-sm">
      <p class="mb-2 font-semibold text-neutral-600 dark:text-neutral-400">목차</p>
      <ul class="space-y-1.5">
        {toc.map((h) => (
          <li class={h.depth === 3 ? 'pl-4' : ''}>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class="text-neutral-600 transition-colors hover:text-accent dark:text-neutral-400"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  /* 현재 섹션 활성 링크. [attr].class 로 명시도를 올려(0,2,0+scope) 링크의
     dark:text-neutral-400 를 확실히 이긴다. --accent 는 다크모드에서 자동 전환. */
  [data-toc-link].is-active {
    color: var(--accent);
  }
</style>

<script is:inline>
  const links = document.querySelectorAll('[data-toc-link]');
  if (links.length) {
    const byId = new Map();
    links.forEach((l) => byId.set(l.getAttribute('data-toc-link'), l));
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          links.forEach((l) => l.classList.remove('is-active'));
          byId.get(entry.target.id)?.classList.add('is-active');
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 1 },
    );
    document.querySelectorAll('article h2[id], article h3[id]').forEach((h) => observer.observe(h));
  }
</script>
