---
import type { Post } from '../utils/posts';

interface Props {
  name: string;
  posts: Post[];
  currentId: string;
}
const { name, posts, currentId } = Astro.props;
---

<!-- 글 상단 시리즈 목차. 형제 글 제목이 본문 인덱스에 섞이지 않도록 pagefind 제외. -->
<nav
  aria-label="시리즈 목차"
  data-pagefind-ignore
  class="mb-8 rounded-lg border border-neutral-200 bg-neutral-50 p-4 dark:border-neutral-800 dark:bg-neutral-900"
>
  <p class="text-sm text-neutral-600 dark:text-neutral-400">시리즈</p>
  <a href={`/series/${name}/`} class="font-semibold tracking-tight hover:text-accent">
    {name}
  </a>
  <ol class="mt-3 space-y-1 text-sm">
    {
      posts.map((p, i) =>
        p.id === currentId ? (
          <li aria-current="true" class="font-medium text-neutral-900 dark:text-neutral-100">
            {i + 1}. {p.data.title}
          </li>
        ) : (
          <li>
            <a
              href={`/posts/${p.id}/`}
              class="text-neutral-600 hover:text-accent dark:text-neutral-400"
            >
              {i + 1}. {p.data.title}
            </a>
          </li>
        ),
      )
    }
  </ol>
</nav>
