---
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import { siteConfig } from '../config';
import type { Post } from '../utils/posts';
import { formatDate, readingTimeMinutes, getSeriesContext } from '../utils/posts';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SeriesNav from '../components/SeriesNav.astro';
import Comments from '../components/Comments.astro';

interface Props {
  post: Post;
  headings: MarkdownHeading[];
}
const { post, headings } = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage } = post.data;
const minutes = readingTimeMinutes(post.body);
const series = await getSeriesContext(post);

const ogPath = `/og/${post.id}.png`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// 글 상세 BlogPosting 구조화 데이터 (검색엔진 리치 결과)
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: siteConfig.author },
  publisher: { '@type': 'Organization', name: siteConfig.title },
  image: new URL(ogPath, Astro.site).href,
  url: canonical,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  keywords: tags,
  inLanguage: siteConfig.locale,
};
---

<BaseLayout title={title} description={description} type="article" image={ogPath} jsonLd={jsonLd}>
  <article data-pagefind-body>
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-400">{description}</p>
      <div
        class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-600 dark:text-neutral-400"
      >
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{minutes}분 읽기</span>
        {
          updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>수정 {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2 text-sm">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}/`}
                class="text-neutral-600 hover:text-accent dark:text-neutral-400"
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {series && <SeriesNav name={series.name} posts={series.posts} currentId={post.id} />}

    {
      heroImage && (
        <Image
          src={heroImage}
          alt={title}
          class="mb-8 w-full rounded-lg"
          widths={[400, 800, 1200]}
          sizes="(max-width: 672px) 100vw, 672px"
        />
      )
    }

    <div class="toc-floating mb-10" data-pagefind-ignore>
      <TableOfContents headings={headings} />
    </div>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>

  {
    series && (series.prev || series.next) && (
      <nav
        aria-label="시리즈 이전/다음 편"
        class="mt-12 grid grid-cols-2 gap-4 border-t border-neutral-200 pt-6 dark:border-neutral-800"
      >
        {series.prev ? (
          <a href={`/posts/${series.prev.id}/`} class="group text-sm">
            <span class="text-neutral-500 dark:text-neutral-400">← 이전 편</span>
            <span class="mt-1 block font-medium group-hover:text-accent">
              {series.prev.data.title}
            </span>
          </a>
        ) : (
          <span />
        )}
        {series.next ? (
          <a href={`/posts/${series.next.id}/`} class="group text-right text-sm">
            <span class="text-neutral-500 dark:text-neutral-400">다음 편 →</span>
            <span class="mt-1 block font-medium group-hover:text-accent">
              {series.next.data.title}
            </span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    )
  }

  <Comments />

  <div class="mt-12 border-t border-neutral-200 pt-6 dark:border-neutral-800">
    <a href="/" class="text-sm text-accent hover:underline"> ← 목록으로 </a>
  </div>
</BaseLayout>

<style>
  /* 목차: 모바일/태블릿은 본문 상단 인라인(기본 흐름) 유지.
     넓은 화면(xl≥1280px)에서는 중앙 정렬된 본문(max-w-2xl=672px)의 오른쪽 여백에
     고정(fixed) 배치 → 스크롤해도 남아 하이라이트 로직이 살아난다.
     TOC 인스턴스는 하나만 두어(중복 data-toc-link 방지) CSS로만 위치를 바꾼다. */
  @media (min-width: 1280px) {
    .toc-floating {
      position: fixed;
      top: 6rem;
      /* 50% = 뷰포트 중앙, +21rem = 본문(672px)의 오른쪽 끝, +1.5rem = 여백 */
      left: calc(50% + 22.5rem);
      width: 14rem;
      max-height: calc(100vh - 8rem);
      margin-bottom: 0;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  }
</style>

<script>
  // 코드블록에 언어 라벨 + 복사 버튼 주입(D6). 마크다운 파이프라인은 건드리지 않고
  // 렌더된 Shiki <pre>(data-language는 shiki transformer가 심음)를 클라이언트에서 감싼다.
  function enhanceCodeBlocks() {
    document.querySelectorAll('article pre.astro-code').forEach((preEl) => {
      const pre = preEl as HTMLElement;
      if (pre.dataset.enhanced) return;
      pre.dataset.enhanced = 'true';

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const tools = document.createElement('div');
      tools.className = 'code-tools';

      const lang = pre.getAttribute('data-language');
      if (lang) {
        const label = document.createElement('span');
        label.className = 'code-lang';
        label.textContent = lang;
        tools.appendChild(label);
      }

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'code-copy';
      btn.textContent = '복사';
      btn.setAttribute('aria-label', '코드 복사');
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code') ?? pre;
        try {
          await navigator.clipboard.writeText(code.textContent ?? '');
          btn.textContent = '복사됨';
        } catch {
          btn.textContent = '실패';
        }
        setTimeout(() => (btn.textContent = '복사'), 1500);
      });
      tools.appendChild(btn);
      wrapper.appendChild(tools);
    });
  }

  enhanceCodeBlocks();
</script>
