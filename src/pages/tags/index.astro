---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags } from '../../utils/posts';

const tags = await getAllTags();
---

<BaseLayout title="Tags" description="태그별 글 모음">
  <h1 class="mb-6 text-2xl font-bold tracking-tight">Tags</h1>

  {
    tags.length === 0 ? (
      <p class="text-neutral-600 dark:text-neutral-400">아직 태그가 없습니다.</p>
    ) : (
      <ul class="flex flex-wrap gap-2">
        {tags.map(({ tag, count }) => (
          <li>
            <a
              href={`/tags/${tag}/`}
              class="rounded-full border border-neutral-300 px-3 py-1 text-sm hover:border-accent hover:text-accent dark:border-neutral-700"
            >
              #{tag} <span class="text-neutral-500 dark:text-neutral-400">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
