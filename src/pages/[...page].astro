---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import { getPublishedPosts, type Post } from '../utils/posts';
import { siteConfig } from '../config';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPublishedPosts();
  return paginate(posts, { pageSize: siteConfig.postsPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<Post> };
const isFirst = page.currentPage === 1;
---

<BaseLayout title={isFirst ? undefined : `${page.currentPage}페이지`}>
  {
    isFirst ? (
      <>
        <section class="mb-10 border-b border-neutral-200 pb-8 dark:border-neutral-800">
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{siteConfig.title}</h1>
          <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-400">
            {siteConfig.description}
          </p>
          <nav aria-label="바로가기" class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
            <a href="/tags" class="text-accent hover:underline">
              태그
            </a>
            <a href="/series" class="text-accent hover:underline">
              시리즈
            </a>
            <a href="/search" class="text-accent hover:underline">
              검색
            </a>
            <a href="/rss.xml" class="text-accent hover:underline">
              RSS
            </a>
          </nav>
        </section>
        <h2 class="mb-2 text-xl font-bold tracking-tight">최근 글</h2>
      </>
    ) : (
      <section class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight">
          최근 글 <span class="font-normal text-neutral-400">· {page.currentPage}페이지</span>
        </h1>
      </section>
    )
  }

  {
    page.data.length === 0 ? (
      <p class="text-neutral-600 dark:text-neutral-400">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="divide-y divide-neutral-200 dark:divide-neutral-800">
        {page.data.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
  />
</BaseLayout>
